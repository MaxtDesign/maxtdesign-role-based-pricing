# Ignore all markdown files except README.md
*.md
!README.md

# Ignore notes folder for critical and performance documentation
notes/

# WordPress specific ignores
wp-config.php
wp-content/uploads/
wp-content/blogs.dir/
wp-content/upgrade/
wp-content/backup-db/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php
wp-content/cache/
wp-content/cache/supercache/

# Plugin development ignores
.cursor/
.DS_Store
Thumbs.db
*.log
*.tmp
*.temp
node_modules/
npm-debug.log
yarn-error.log

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Backup files
*.bak
*.backup
*.old

# Temporary files
*.tmp
*.temp

# WordPress Plugin Directory upload files
svn-upload/
.svnignore

# Development and documentation files
docs/
PROJECT_CONTEXT.md

# WordPress Plugin Directory assets (these should be in svn-upload only)
assets/banner-*.png
assets/icon-*.png
assets/screenshot-*.png

# Development documentation
*.md
!README.md
!readme.txt

# SVN and deployment files
SVN_UPLOAD_INSTRUCTIONS.md